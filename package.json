{
  "name": "versa",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "bun services:up && bun migrate:latest && nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "bun services:up && wait-on tcp:5432 && (APP_ENV=test nuxt dev &) && bunx vitest",
    "test:watch": "bun run test -- --watch",
    "services:up": "docker compose up --wait",
    "services:stop": "docker compose stop",
    "services:down": "docker compose down",
    "migrate:create": "bun run server/infra/database/migrations-create.ts",
    "migrate:latest": "bun node_modules/.bin/knex migrate:latest",
    "migrate:rollback": "bun node_modules/.bin/knex migrate:rollback",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "dependencies": {
    "@lucide/vue": "^1.17.0",
    "@nuxt/eslint": "1.15.2",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "knex": "^3.2.10",
    "nuxt": "^4.4.6",
    "pg": "^8.21.0",
    "reka-ui": "^2.9.8",
    "shadcn-nuxt": "2.7.3",
    "tailwind-merge": "^3.6.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7",
    "wait-on": "^9.0.10",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.3",
    "@nuxtjs/tailwindcss": "7.0.0-beta.1",
    "@types/pg": "^8.20.0",
    "@types/wait-on": "^5.3.4",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^9.0.0 || ^10.0.0",
    "happy-dom": "^20.9.0",
    "prettier": "3.9.4",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
